{
  "expo": {
    "name": "TFH Partner",
    "slug": "thefamoushalwaipartners",
    "version": "1.8",
    "orientation": "portrait",
    "icon": "./assets/app_assets/icon.png",
    "splash": {
      "image": "./assets/app_assets/Group1171283339-2.png",
      "resizeMode": "cover",
      "backgroundColor": "#EA243F"
    },
    "scheme": "thf",
    "userInterfaceStyle": "automatic",
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCctEGlkUkIMBepdzLf60eqtrgxxt_E3JE"
        }
      },
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/app_assets/Adaptive.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.thfpartnerv1.next.myapp",
      "versionCode": 9,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow THF to access your camera to take photos for KYC and profile.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow THF to access your photos for uploading documents.",
          "cameraPermission": "Allow THF to access your camera to take photos for KYC and profile."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "assets/app_assets/Maskgroup.png",
          "color": "#ffffff",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow TFH Partner to use your location services to show booking addresses on the map."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e25745ee-b3e0-4d4b-b3cd-d17eef70776f"
      }
    },
    "owner": "mohit551"
  }
}
